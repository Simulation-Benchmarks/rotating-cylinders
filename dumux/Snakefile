import json
import os
from pathlib import Path

# Use workflow.basedir to find the root relative to the Snakefile
shared_dir = Path(workflow.basedir).parent
container_image = "git.iws.uni-stuttgart.de:4567/benchmarks/rotating-cylinders:3.1"
container_shared_dir = "/dumux/shared"

rule all:
    input:
        "solution_metrics.json",
        "test_rotatingcylinders.zip"

rule run_simulation:
    input:
        rc_parameters_file = "parameters.json"
    output:
        zip = "test_rotatingcylinders.zip",
        metrics = "solution_metrics.json"
    resources:
        serial_run=1
    singularity:
        f"docker://{container_image}"
    run:
        # Read parameters from the local JSON
        with open(input.rc_parameters_file, 'r') as f:
            data = json.load(f)

        conf_name = data['configuration']
        r1, r2 = data['domain']['r1'], data['domain']['r2']
        c_radial = data['grid']['cells_radial']
        c_angular = data['grid']['cells_angular']
        grading = data['grid']['grading']
        omega1 = data['problem']['omega1']
        omega2 = data['problem']['omega2']
        
        midpoint = 0.5 * (r1 + r2)
        half_radial = int(c_radial / 2)

        shell(
            f"""
            set -euo pipefail
            cd /dumux/rotating-cylinders/build-cmake/test/freeflow/navierstokes/rotatingcylinders
            
            # Run simulation. We use the container_shared_dir mount point to save results back to the host
            ./test_ff_navierstokes_rotatingcylinders \
                -Grid.Cells0 "{half_radial} {half_radial}" \
                -Grid.Cells1 "{c_angular}" \
                -Grid.Grading0 "{grading} -{grading}" \
                -Grid.Radial0 "{r1} {midpoint} {r2}" \
                -Problem.Omega1 "{omega1}" \
                -Problem.Omega2 "{omega2}" \
                -Problem.Name "{container_shared_dir}/results/{conf_name}/test_rotatingcylinders"
            """
        )